{
  "name": "bizcopilot",
  "version": "1.0.0",
  "description": "AI-Powered Business Intelligence Copilot",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && node src/index.js",
    "install:all": "npm install --legacy-peer-deps && cd server && npm install --legacy-peer-deps && cd ../client && npm install --legacy-peer-deps"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}