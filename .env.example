# Server
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/bizcopilot
JWT_SECRET=your-jwt-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Composio (optional — enables one-click Slack OAuth)
COMPOSIO_API_KEY=

# Slack (optional — fallback if Composio not configured)
SLACK_WEBHOOK_URL=

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
